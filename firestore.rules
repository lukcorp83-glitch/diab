rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Authentication helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isLinked(userId) {
      return userId != null && userId != "" && exists(/databases/$(database)/documents/artifacts/diacontrolapp/users/$(userId)/linkRequests/$(request.auth.uid));
    }

    function canAccessUser(userId) {
      return isOwner(userId) || isLinked(userId);
    }

    // FCM tokens for push notifications
    match /fcm_tokens/{userId} {
      allow read, write: if isOwner(userId);
    }

    // Main application data structure
    match /artifacts/diacontrolapp {
      // Shared collections
      match /syncCodes/{codeId} {
        allow read, write: if isSignedIn();
      }

      match /communityProducts/{productId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn() && request.resource.data.authorId == request.auth.uid;
        allow update, delete: if isSignedIn() && resource.data.authorId == request.auth.uid;
      }

      match /apiSecrets/{apiSecretHash} {
        // Prevent list queries, only get by known hash. Allow write only for current user's data.
        allow get: if isSignedIn() && resource.data.userId == request.auth.uid;
        allow create, update: if isSignedIn() && request.resource.data.userId == request.auth.uid;
        allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
      }

      match /glikosense_training/{docId} {
        allow create: if isSignedIn();
        allow read: if false;
      }

      // Public connection tests (restricted to prevent abuse)
      match /connection_tests/{docId} {
        allow get: if true;
        allow create: if true && docId == "test"; // only allow one specific test document
        allow update, delete: if false;
      }

      match /tests/{testId} {
        allow get: if true;
        allow create: if true && testId == "test";
        allow update, delete: if false;
      }

      // User-specific data
      match /users/{userId} {
        allow read, write: if isOwner(userId);

        match /linkRequests/{requesterUid} {
          allow read, delete: if isSignedIn() && (userId == request.auth.uid || requesterUid == request.auth.uid);
          allow create, update: if isSignedIn() && requesterUid == request.auth.uid;
        }

        match /{allSub=**} {
          allow read, write: if canAccessUser(userId);
        }
      }
    }
  }
}
