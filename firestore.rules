rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128;
    }

    match /artifacts/diacontrolapp/communityProducts/{productId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    match /artifacts/diacontrolapp/users/{userId} {
      // User can manage their own data
      match /logs/{logId} {
        allow read, write: if isOwner(userId);
      }
      
      match /aiReports/{reportId} {
        allow read, write: if isOwner(userId);
      }
      
      match /settings/{docId} {
        allow read, write: if isOwner(userId);
      }
      
      match /shortcuts/{shortcutId} {
        allow read, write: if isOwner(userId);
      }
      
      match /customProducts/{productId} {
        allow read, write: if isOwner(userId);
      }
      
      match /savedMeals/{mealId} {
        allow read, write: if isOwner(userId);
      }
    }
  }
}
