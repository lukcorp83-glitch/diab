rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default allow all
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isLinked(userId) {
      return userId != null && userId != "" && exists(/databases/$(database)/documents/artifacts/diacontrolapp/users/$(userId)/linkRequests/$(request.auth.uid));
    }

    function isOwner(userId) {
      return isSignedIn() && (request.auth.uid == userId || isLinked(userId));
    }

    function isValidId(id) {
      return id is string && id.size() <= 128;
    }

    match /artifacts/diacontrolapp/syncCodes/{codeId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    match /artifacts/diacontrolapp/communityProducts/{productId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    match /artifacts/diacontrolapp/tests/{testId} {
      allow read, write: if true;
    }

    match /artifacts/diacontrolapp/apiSecrets/{apiSecretHash} {
      allow read, delete: if isSignedIn();
      allow create, update: if isSignedIn();
    }

    match /artifacts/diacontrolapp/users/{userId} {
      allow read: if false;
      allow write: if false;
      
      match /linkRequests/{parentUid} {
        allow read, delete: if isSignedIn() && (userId == request.auth.uid || parentUid == request.auth.uid);
        allow create, update: if isSignedIn() && parentUid == request.auth.uid &&
          exists(/databases/$(database)/documents/artifacts/diacontrolapp/users/$(userId)) &&
          'syncSecret' in get(/databases/$(database)/documents/artifacts/diacontrolapp/users/$(userId)).data &&
          request.resource.data.syncSecret == get(/databases/$(database)/documents/artifacts/diacontrolapp/users/$(userId)).data.syncSecret;
      }

      // User can manage their own data
      match /logs/{logId} {
        allow read, write: if isOwner(userId);
      }
      
      match /aiReports/{reportId} {
        allow read, write: if isOwner(userId);
      }
      
      match /settings/{docId} {
        allow read, write: if isOwner(userId);
      }
      
      match /shortcuts/{shortcutId} {
        allow read, write: if isOwner(userId);
      }
      
      match /customProducts/{productId} {
        allow read, write: if isOwner(userId);
      }
      
      match /savedMeals/{mealId} {
        allow read, write: if isOwner(userId);
      }
    }
  }
}
