VITE_FIREBASE_AUTH_DOMAIN="diacontrolapp.firebaseapp.com"
VITE_FIREBASE_PROJECT_ID="diacontrolapp"
VITE_FIREBASE_STORAGE_BUCKET="diacontrolapp.firebasestorage.app"
